# Copie este arquivo para ".env" e preencha com seus dados reais.
# O arquivo ".env" (sem .example) NUNCA deve ser commitado no Git.

# API Key da Magalu Cloud (gerada no Console > API Keys)
MGC_API_KEY=

# Regiao da API: br-se1 ou br-ne1
MGC_REGION=br-se1

# Endpoint de consumo/FOCUS (ajuste se necessario apos confirmar na documentacao)
MGC_USAGE_ENDPOINT=https://api.magalu.cloud/{region}/billing/v1/usage